{
  "manifest_version": 3,
  "name": "Already Own?",
  "version": "1.4.0",
  "description": "Shows your Epic and Steam libraries on store pages so you never buy a game you already own. Scans both Epic and Steam.",
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "cookies"
  ],
  "host_permissions": [
    "https://store.epicgames.com/*",
    "https://store.steampowered.com/*",
    "https://www.epicgames.com/*",
    "https://graphql.epicgames.com/*",
    "https://launcher-public-service-prod06.ol.epicgames.com/*",
    "https://library-service.live.use1a.on.epicgames.com/*",
    "https://account-public-service-prod.ol.epicgames.com/*",
    "https://catalog-public-service-prod06.ol.epicgames.com/*",
    "https://steamcommunity.com/*",
    "https://api.steampowered.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://store.epicgames.com/*", "https://www.epicgames.com/*"],
      "js": ["content_epic.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://store.steampowered.com/app/*"],
      "js": ["content_steam.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
